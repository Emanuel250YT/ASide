{
  "name": "@emanuel250dev/aside",
  "version": "1.0.3",
  "description": "Temporary user profiles linked to blockchain wallets, with cross-chain replication and per-app extensions - powered by ArkaCDN.",
  "license": "MIT",
  "author": "Emanuel250yt",
  "type": "module",
  "repository": {
    "url": "https://github.com/Emanuel250YT/ASide"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "pnpm typecheck && pnpm test && changelogen --release && bumpp --commit --tag --push"
  },
  "dependencies": {
    "@arkiv-network/sdk": ">=0.6.0",
    "arka-cdn": "^0.1.2-beta.5",
    "viem": ">=2.0.0"
  },
  "devDependencies": {
    "bumpp": "^10.4.1",
    "changelogen": "^0.5.7",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}